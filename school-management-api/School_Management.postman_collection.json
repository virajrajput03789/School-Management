{
	"info": {
		"_postman_id": "a9e5b7c0-d6e1-4b1a-8c3e-f8d2b7a9c1e0",
		"name": "School Management API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Schools",
			"item": [
				{
					"name": "Add School",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Delhi Public School\",\n  \"address\": \"Sector 45, Gurugram\",\n  \"latitude\": 28.4595,\n  \"longitude\": 77.0266\n}"
						},
						"url": {
							"raw": "{{base_url}}/addSchool",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"addSchool"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 201\", () => pm.response.to.have.status(201))"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "List Schools",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/listSchools?latitude=28.6139&longitude=77.2090",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"listSchools"
							],
							"query": [
								{
									"key": "latitude",
									"value": "28.6139"
								},
								{
									"key": "longitude",
									"value": "77.2090"
								}
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200))",
									"pm.test(\"Returns array\", () => pm.expect(pm.response.json()).to.be.an('array'))"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000",
			"type": "string"
		}
	]
}
